  "keyFeatures": [
    "@RateLimit annotation for method and class-level throttling",
    "Redis fixed-window implementation using INCR + TTL",
    "Automatic Spring Boot 3.x auto-configuration",
    "HTTP 429 mapping with Retry-After and RateLimit-* headers",
    "Pluggable key resolution and policy strategies",
    "Configurable fail-open or fail-closed backend behavior",
    "Micrometer metrics support for monitoring"
  ],
